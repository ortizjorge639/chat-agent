# ── Data source ───────────────────────────────────────
DATASOURCE=excel                       # "excel" for local testing, "sql" for production
EXCEL_FOLDER_PATH=./data/mock          # folder with .xlsx files (used when DATASOURCE=excel)

# Uncomment and fill these when switching to SQL Server:
# SQL_SERVER=your-server-hostname-or-ip
# SQL_DATABASE=your-database-name
# SQL_TABLE=your-table-or-view-name
# SQL_TRUSTED_CONNECTION=yes           # "yes" for Windows auth
# SQL_USERNAME=                        # only needed for SQL auth
# SQL_PASSWORD=                        # only needed for SQL auth

# ── Azure OpenAI (required) ──────────────────────────
# If you already have a deployment from the data extraction experiment,
# just paste that endpoint/key/deployment name here. Any model with
# tool calling support works (GPT-4o, GPT-4.1 mini, GPT-5 mini, etc.).
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5-mini  # mini model is ideal — this is tool-routing, not complex reasoning

# ── Bot Framework (only needed for Teams) ─────────────
MICROSOFT_APP_ID=                      # leave blank for local-only testing
MICROSOFT_APP_PASSWORD=                # leave blank for local-only testing
MICROSOFT_APP_TENANT_ID=               # leave blank for local-only testing

# ── Server ────────────────────────────────────────────
BOT_PORT=3978
LOG_LEVEL=INFO
